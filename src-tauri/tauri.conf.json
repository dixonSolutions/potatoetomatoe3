{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Potato Tomato",
  "version": "0.0.1",
  "identifier": "com.potatotomato.games",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://127.0.0.1:5173/home",
    "beforeDevCommand": "node scripts/generate-games-list.js && vite dev",
    "beforeBuildCommand": "node scripts/generate-games-list.js && pnpm build && pnpm puller:bundle:linux"
  },
  "app": {
    "windows": [
      {
        "title": "Potato Tomato",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/puller-sidecar"
    ],
    "resources": {
      "../build/games/": "catalog/games/",
      "../puller/dist/index.js": "puller/index.js"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
