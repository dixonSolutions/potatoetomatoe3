{
  "name": "project-potato-tomato",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-games-list.js && node scripts/dev-with-puller.mjs vite dev --open",
    "app": "node scripts/generate-games-list.js && tauri dev",
    "build": "node scripts/generate-games-list.js && vite build && node scripts/prepare-github-pages.mjs",
    "tauri": "tauri",
    "tauri:dev": "pnpm app",
    "tauri:build": "tauri build",
    "tauri:build:flatpak": "tauri build --no-bundle",
    "tauri:build:debug": "node scripts/generate-games-list.js && tauri build --debug --no-bundle",
    "flatpak:build": "flatpak-builder --force-clean --user --install-deps-from=flathub build-flatpak flatpak/com.potatotomato.games.yml",
    "flatpak:install": "flatpak-builder --force-clean --user --install build-flatpak flatpak/com.potatotomato.games.yml",
    "flatpak:run": "flatpak run com.potatotomato.games",
    "preview": "node scripts/generate-games-list.js && vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "port-game": "node scripts/port-game.js",
    "games:restore-from-build": "node scripts/restore-games-from-build.mjs",
    "games:strip-missing-thumbnails": "node scripts/strip-missing-thumbnail-paths.mjs",
    "puller:start": "pnpm --filter @potatotomato/puller start",
    "puller:dev": "pnpm --filter @potatotomato/puller dev",
    "puller:build": "pnpm --filter @potatotomato/puller build",
    "puller:bundle:linux": "pnpm --filter @potatotomato/puller bundle:linux"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.36.0",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.544.0",
    "@storybook/addon-docs": "^9.1.15",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/addon-vitest": "^9.1.15",
    "@storybook/sveltekit": "^9.1.15",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.43.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.5",
    "@types/node": "^22",
    "@vitest/browser": "^3.2.4",
    "bits-ui": "^2.14.1",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^9.1.15",
    "eslint-plugin-svelte": "^3.12.4",
    "formsnap": "^2.0.1",
    "globals": "^16.4.0",
    "layerchart": "2.0.0-next.27",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "storybook": "^9.1.15",
    "svelte": "^5.39.5",
    "svelte-check": "^4.3.2",
    "svelte-sonner": "^1.0.5",
    "sveltekit-superforms": "^2.28.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.1.7",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^3.2.4",
    "vitest-browser-svelte": "^1.1.0"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "fuse.js": "^7.0.0",
    "lucide-svelte": "^0.548.0"
  }
}